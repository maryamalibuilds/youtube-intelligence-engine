# Copy to .env and fill in. .env is gitignored.

# --- YouTube Data API v3 ---
# Get a key: https://console.cloud.google.com/ -> enable "YouTube Data API v3"
YOUTUBE_API_KEY=

# --- LLM provider (choose one; leave the other blank) ---
# The RAG generator + agent will use whichever is set.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Which provider to prefer: "openai" | "anthropic" | "local"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# --- Paths / settings (sensible defaults; override if you want) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_DB_DIR=./data/processed/chroma
MLFLOW_TRACKING_URI=./mlruns
