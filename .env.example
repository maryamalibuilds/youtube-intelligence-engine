# Copy to .env and fill in. .env is gitignored.

# --- YouTube Data API v3 ---
# Get a key: https://console.cloud.google.com/ -> enable "YouTube Data API v3"
YOUTUBE_API_KEY=

# --- LLM provider ---
# Default is Groq: free + fast. Get a key (no card): https://console.groq.com/keys
GROQ_API_KEY=
# Optional alternatives (leave blank unless you switch LLM_PROVIDER):
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Which provider to use: "groq" | "openai" | "anthropic" | "local"
LLM_PROVIDER=groq
# Leave blank to auto-pick a good default per provider (groq -> llama-3.3-70b-versatile)
LLM_MODEL=

# --- Paths / settings (sensible defaults; override if you want) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_DB_DIR=./data/processed/chroma
MLFLOW_TRACKING_URI=./mlruns
